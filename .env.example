# CC-Proxy 启动配置文件（YAML 格式）
# 复制此文件为 .env 并填入实际值：cp .env.example .env
# 请勿将 .env 文件提交到版本控制系统！

# ============================================
# 数据库配置（openGauss）
# ============================================
database:
  host: "192.168.0.98"
  port: 5432
  name: "cc_proxy"
  user: "grigs"
  password: "${DB_PASSWORD:-your_password}"

# ============================================
# 服务器配置
# ============================================
server:
  host: "0.0.0.0"
  port: 5566

# ============================================
# 管理密码（首次启动使用默认密码 admin）
# ============================================
admin_password: "admin"

# ============================================
# SSO 配置（可选）
# ============================================
# yz_login_enabled: true
# yz_login_url: "http://192.168.0.18:5551"
# cc_proxy_callback_url: "http://192.168.0.19:5566/api/yz/callback"

# ============================================
# 说明
# ============================================
# 提供商、模型、用户、模型映射、透传路径等运行时数据
# 均存储在数据库中，通过管理面板操作，无需手动编辑。
# 首次启动时会自动从旧的 providers 配置迁移数据到数据库。
