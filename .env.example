# CC-Proxy 配置文件（YAML 格式）
# 复制此文件为 .env 并填入实际值：cp .env.example .env
# 请勿将 .env 文件提交到版本控制系统！
#
# API Key 支持两种写法：
#   1. 直接写：api_key: "sk-ant-your-key-here"
#   2. 环境变量引用：api_key: "${ANTHROPIC_API_KEY}"
#      系统会自动查找环境变量 ANTHROPIC_API_KEY 的值
#      也支持默认值：api_key: "${ANTHROPIC_API_KEY:-sk-ant-xxx}"

# ============================================
# 双端口双模式配置说明
# ============================================
# CC_MODE: 运行模式
#   anthropic - 监听 CC_ANthropic_PORT（默认 5566），仅处理 Anthropic 格式请求
#   openai    - 监听 CC_OpenAI_PORT（默认 5567），仅处理 OpenAI 兼容格式请求
#   all       - 同时监听两个端口（默认模式）
#
# CC_PORT: 通用监听端口（默认 5566）
# CC_ANthropic_PORT: Anthropic 模式专用端口（默认 5566）
# CC_OpenAI_PORT: OpenAI 模式专用端口（默认 5567）
#
# 示例：CC_MODE=all CC_ANthropic_PORT=5566 CC_OpenAI_PORT=5567

# ============================================
# Anthropic 模式服务器配置 (端口 5566)
# ============================================
server_anthropic:
  host: "0.0.0.0"
  port: 5566

# ============================================
# OpenAI 模式服务器配置 (端口 5567)
# ============================================
server_openai:
  host: "0.0.0.0"
  port: 5567

# ============================================
# 通用服务器配置（单端口模式）
# ============================================

server:
  host: "0.0.0.0"
  port: 5566

providers:
  # Anthropic 直通 - 不进行格式转换
  - name: "Anthropic 直通"
    type: "anthropic"
    supported_formats: ["anthropic"]  # 支持的格式：anthropic 和/或 openai
    base_url: "https://api.anthropic.com"
    api_key: "${ANTHROPIC_API_KEY:-sk-ant-xxx}"
    timeout: 300
    models:
      - id: "claude-sonnet-4-20250514"
        display_name: "Claude Sonnet 4"
        supported_formats: ["anthropic"]  # 支持的格式：anthropic 和/或 openai
      - id: "claude-haiku-4-5-20251001"
        display_name: "Claude Haiku 4.5"
        supported_formats: ["anthropic"]

  # OpenAI 兼容中转站
  - name: "中转站"
    type: "openai"
    supported_formats: ["openai"]
    base_url: "https://your-relay.example.com"
    api_key: "${RELAY_API_KEY:-sk-xxx}"
    timeout: 300
    models:
      - id: "gpt-4o"
        display_name: "GPT-4o"
        supported_formats: ["openai"]
      - id: "gpt-4o-mini"
        display_name: "GPT-4o Mini"
        supported_formats: ["openai"]

  # Moonshot (Kimi)
  - name: "Kimi"
    type: "openai"
    supported_formats: ["openai"]
    base_url: "https://api.moonshot.cn/v1"
    api_key: "${MOONSHOT_API_KEY:-sk-xxx}"
    timeout: 300
    models:
      - id: "moonshot-v1-128k"
        display_name: "Moonshot V1 128K"
        supported_formats: ["openai"]

  # 智谱 AI
  - name: "智谱"
    type: "openai"
    supported_formats: ["openai"]
    base_url: "https://open.bigmodel.cn/api/paas/v4"
    api_key: "${ZHIPU_API_KEY:-xxx}"
    timeout: 300
    models:
      - id: "glm-4"
        display_name: "GLM-4"
        supported_formats: ["openai"]

  # 本地模型 (Ollama / vLLM 等)
  - name: "本地模型"
    type: "openai"
    supported_formats: ["openai"]
    base_url: "http://localhost:11434/v1"
    api_key: "none"
    timeout: 600
    models:
      - id: "qwen2.5:27b"
        display_name: "Qwen 2.5 27B"
        supported_formats: ["openai"]

# 模型映射：将请求的模型名映射到提供商支持的模型名
model_map: {}
  # claude-sonnet-4-20250514: "gpt-4o"

# 管理界面密码（首次启动使用默认密码 admin，登录后强制要求修改）
admin_password: "admin"
